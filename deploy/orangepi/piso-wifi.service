[Unit]
Description=Piso WiFi Portal
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/piso-wifi
ExecStart=/opt/piso-wifi/deploy/orangepi/run.sh
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStartPre=/bin/test -f /opt/piso-wifi/config.json
ExecStartPre=/bin/test -x /opt/piso-wifi/.venv/bin/python

[Install]
WantedBy=multi-user.target
